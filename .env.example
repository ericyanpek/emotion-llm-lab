# Example environment variables for local dev.
# Copy to .env (gitignored) and edit:
#   cp .env.example .env
#
# .env is loaded automatically by python-dotenv in scripts; for shell scripts
# you can `set -a; source .env; set +a` before invoking infrastructure/scripts.

# --- AWS / deployment -------------------------------------------------------
AWS_REGION=us-east-1
AWS_PROFILE=default               # leave blank to use default or env creds
STACK_NAME=emotion-companion-dev
PROJECT_NAME=emotion-companion
ENVIRONMENT=dev

# --- Compute sizing ---------------------------------------------------------
INSTANCE_TYPE=g5.2xlarge
USE_SPOT=false
ROOT_VOLUME_GB=500
AUTO_SHUTDOWN_HOURS=8

# --- Cost guardrail ---------------------------------------------------------
BUDGET_LIMIT_USD=200
BUDGET_EMAIL=                     # leave blank to skip budget alerts

# --- Eval / LLM-as-judge (only needed for running eval scripts locally) -----
# Store production versions in SSM Parameter Store; these are for local dev.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
HF_TOKEN=                         # Hugging Face read token

# --- Weights & Biases (optional) --------------------------------------------
WANDB_API_KEY=
WANDB_PROJECT=emotion-companion
WANDB_ENTITY=
